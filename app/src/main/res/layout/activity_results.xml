<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title + stance badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Session Results"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutStanceBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </LinearLayout>

        <!-- Punch counts -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#1E1E1E" android:padding="12dp" android:gravity="center"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TOTAL" android:textColor="#888888" android:textSize="11sp"/>
                <TextView android:id="@+id/tvTotal" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="#FFFFFF" android:textSize="34sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#1E1E1E" android:padding="12dp" android:gravity="center"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="JABS" android:textColor="#4CAF50" android:textSize="11sp"/>
                <TextView android:id="@+id/tvJabs" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="#FFFFFF" android:textSize="34sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#1E1E1E" android:padding="12dp" android:gravity="center"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CROSS" android:textColor="#2196F3" android:textSize="11sp"/>
                <TextView android:id="@+id/tvCrosses" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="#FFFFFF" android:textSize="34sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#1E1E1E" android:padding="12dp" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="HOOKS" android:textColor="#FF9800" android:textSize="11sp"/>
                <TextView android:id="@+id/tvHooks" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="#FFFFFF" android:textSize="34sp" android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Feedback -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Coach Feedback" android:textColor="#FFFFFF"
            android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/tvFeedback" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="#CCCCCC"
            android:textSize="15sp" android:background="#1E1E1E" android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvGuardFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F44336"
            android:textSize="15sp"
            android:background="#1E1E1E"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"/>

        <!-- Strengths -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Strengths" android:textColor="#4CAF50"
            android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <LinearLayout android:id="@+id/layoutStrengths"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#1E1E1E"
            android:padding="12dp" android:layout_marginBottom="16dp"/>

        <!-- Improvements -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Areas to Improve" android:textColor="#FF9800"
            android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <LinearLayout android:id="@+id/layoutImprovements"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#1E1E1E"
            android:padding="12dp" android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnToggleTimeline"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Show Punch Timeline ▼"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:backgroundTint="#333333"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:id="@+id/layoutTimeline"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#1E1E1E"
            android:padding="12dp" android:layout_marginBottom="24dp"/>

        <Button android:id="@+id/btnNewSession"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="New Session" android:textColor="#FFFFFF"
            android:textSize="16sp" android:backgroundTint="#43A047" />

    </LinearLayout>
</ScrollView>